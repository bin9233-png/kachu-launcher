{
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devPath": "http://localhost:5173",
    "distDir": "../ui/dist"
  },
  "package": {
    "productName": "Kachu Launcher",
    "version": "0.1.0"
  },
  "tauri": {
    "windows": [
      {
        "title": "Kachu Launcher",
        "width": 1100,
        "height": 720,
        "resizable": true
      }
    ],
    "bundle": {
      "active": true,
      "targets": ["msi", "nsis"],
      "identifier": "com.kachu.launcher",
      "icon": ["icons/icon.ico"]
    },
    "security": {
      "csp": null
    }
  }
}
